    if opt_choice.lower() == "adam":
        eff_optimizer = optim.Adam(eff_model.parameters(), lr=1e-4, weight_decay=1e-4)
    else:
        eff_optimizer = optim.Adagrad(eff_model.parameters(), lr=1e-3, weight_decay=1e-4)

    eff_scheduler = lr_scheduler.StepLR(eff_optimizer, step_size=5, gamma=0.1)

    eff_model, eff_history = train_model(
        eff_model, criterion, eff_optimizer, scheduler=eff_scheduler,
        num_epochs=num_epochs, model_name="EfficientNet-B3", is_vit=False
    )
    plot_curves(eff_history, model_name="EfficientNet-B3")
    eff_acc, eff_p, eff_r, eff_f1, eff_auc = evaluate_with_metrics(
        eff_model, model_name="EfficientNet-B3", is_vit=False
