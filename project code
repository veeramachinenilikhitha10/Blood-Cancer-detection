        den_model, criterion, den_optimizer, scheduler=den_scheduler,
        num_epochs=num_epochs, model_name="DenseNet-201", is_vit=False
    )
    plot_curves(den_history, model_name="DenseNet-201")
    den_acc, den_p, den_r, den_f1, den_auc = evaluate_with_metrics(
        den_model, model_name="DenseNet-201", is_vit=False
    )
    den_path = os.path.join(base_dir, "densenet201_blood_cancer.pth")
